# ─────────────────────────────────────────────
#  Byte-compiled / cache
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ─────────────────────────────────────────────
#  Virtual environments
# ─────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.python-version

# ─────────────────────────────────────────────
#  Distribution / build
# ─────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
*.spec

# ─────────────────────────────────────────────
#  Installers (PyInstaller / cx_Freeze / Nuitka)
# ─────────────────────────────────────────────
*.exe
*.msi
*.pkg

# ─────────────────────────────────────────────
#  IDE / editor config
# ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.sln.docstates
.vs/

# ─────────────────────────────────────────────
#  Logs & temp files
# ─────────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*~

# ─────────────────────────────────────────────
#  OS-specific
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
#  Excel & Office files (targets / test files)
#  Do NOT commit protected files to the repo.
# ─────────────────────────────────────────────
*.xlsx
*.xlsm
*.xls
*.xlsb
*.doc
*.docx
*.ppt
*.pptx

# ─────────────────────────────────────────────
#  Wordlists (can be large/sensitive)
# ─────────────────────────────────────────────
wordlists/
*.wordlist
rockyou.txt

# ─────────────────────────────────────────────
#  Output files generated by the tool
# ─────────────────────────────────────────────
*_UNLOCKED.*

# ─────────────────────────────────────────────
#  pytest / coverage
# ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ─────────────────────────────────────────────
#  mypy / type checkers
# ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json